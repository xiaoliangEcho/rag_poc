alias femu_login="ssh pithos@172.24.100.2"
alias femu_start="cd /home/zoe/SSD/femu&&sudo ./build/qemu-system-x86_64     -enable-kvm     -m 4096     -smp 4     -drive file=/home/zoe/SSD/images/u20s.qcow2,if=none,id=drive0,format=qcow2     -device nvme,serial=1234,drive=drive0  -net nic -net tap,ifname=tap0,script=no,downscript=no -monitor tcp:127.0.0.1:4444,server,nowait"
alias qemu_start='cd /home/zoe/SSD/qemu/build&&./qemu-system-aarch64     -machine virt     -cpu cortex-a72     -m 2048     -kernel /home/zoe/SSD/qemu/Image     -drive file=/home/zoe/SSD/images/rootfs.img,format=raw,id=hd0,if=none     -device virtio-blk-device,drive=hd0     -append "root=/dev/vda console=ttyAMA0 nokaslr"     -nographic'
alias llama_cli='/home/zoe/llama.cpp/build/bin/llama-cli -m /home/zoe/llama.cpp/models/qwen2.5-3b-instruct-q4_k_m.gguf'
alias llama_server='/home/zoe/llama.cpp/build/bin/llama-server -m /home/zoe/llama.cpp/models/qwen2.5-3b-instruct-q4_k_m.gguf --host 0.0.0.0  --port 8001  -c 4096 --temp 0.2 --jinja'
alias agent_env='source /home/zoe/llama.cpp/agent_env/bin/activate'
alias t='tmux attach -t 0'
